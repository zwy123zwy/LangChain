# 可选：Ollama 模型与地址（不填则用默认）
# OLLAMA_MODEL=qwen3-coder:480b-cloud
# OLLAMA_BASE_URL=http://localhost:11434

# 在 LangSmith 中看到 runs（必填此项才能看到连载/追踪）
# 获取方式：登录 https://smith.langchain.com → Settings → API Keys → Create
# 创建后取消下面注释并填入你的 key（不要引号）
# LANGSMITH_API_KEY=lsv2_pt_xxxxxxxxxxxxxxxx

# 若出现 "Failed to extract schema for agent"：拉长 schema 提取超时（毫秒），默认 30000
# LANGGRAPH_SCHEMA_RESOLVE_TIMEOUT_MS=120000

# read_file 工具可读文件根目录（不填则默认使用项目根目录下的 uploads）
# UPLOADS_DIR=/absolute/path/to/chain/uploads
